# Server
PORT=3006
NODE_ENV=development

# Database
DATABASE_URL=postgresql://deployx:deployx@localhost:5432/deployx?schema=public

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string

# Redis
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/auth/oauth/github/callback

# OAuth - GitLab
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_CALLBACK_URL=http://localhost:3001/auth/oauth/gitlab/callback

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/oauth/google/callback

# Git Webhooks
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=

# Git Provider PATs (for fetching repos)
GITHUB_PAT=
GITLAB_PAT=

# GitHub App Token (for PR comments)
GITHUB_APP_TOKEN=

# CORS
CORS_ORIGIN=http://localhost:3000

# Client URL
CLIENT_URL=http://localhost:3000

# Encryption (32-byte key for env variable encryption)
ENCRYPTION_KEY=change-me-to-a-32-byte-encryption-key!!

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@deployx.app

# Stripe
STRIPE_SECRET_KEY=

# Sentry
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.2
