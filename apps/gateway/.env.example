# Server
PORT=3004

# Redis
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Gateway
DEFAULT_DOMAIN=deployx.app

# Traefik
TRAEFIK_ENABLED=false
TRAEFIK_NAMESPACE=deployx-gateway
TRAEFIK_API_URL=http://localhost:8080
TRAEFIK_PROVIDER_POLL_INTERVAL=5000

# SSL / ACME
SSL_CERT_DIR=./certs
ACME_EMAIL=admin@deployx.app
ACME_DIRECTORY_URL=https://acme-v02.api.letsencrypt.org/directory

# Proxy
PROXY_TIMEOUT=30000
PROXY_READ_TIMEOUT=60000
