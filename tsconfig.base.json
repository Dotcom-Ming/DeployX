{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@deployx/database": ["./packages/database/src"],
      "@deployx/shared": ["./packages/shared/src"],
      "@deployx/auth": ["./packages/auth/src"],
      "@deployx/ui": ["./packages/ui/src"],
      "@deployx/sdk": ["./packages/sdk/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".turbo"]
}
